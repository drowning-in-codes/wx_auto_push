# 微信公众号配置
WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret
WECHAT_TEMPLATE_ID=your_template_id

# 大模型配置
LLM_ENABLED=false
LLM_MODEL=openai

# OpenAI配置
OPENAI_API_KEY=your_api_key
OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# Gemini配置
GEMINI_API_KEY=your_gemini_api_key
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1/models/gemini-1.5-flash-lite:generateContent

# 缓存配置
CACHE_TYPE=local  # local或redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# 调度配置
WEEKLY_FREQUENCY=3
TIME_RANGE_START=08:00
TIME_RANGE_END=20:00